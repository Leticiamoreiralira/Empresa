      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from tensorflow import keras\n",
        "from tensorflow.keras import layers\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# semente de reprodutibilidade\n",
        "np.random.seed(42)\n",
        "keras.utils.set_random_seed(42)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Palavras positivas\n",
        "positivos = [\n",
        " \"ótimo\", \"excelente\", \"incrível\", \"maravilhoso\", \"perfeito\",\n",
        " \"amei\", \"gostei\", \"agradável\", \"satisfeito\", \"recomendo\",\n",
        " \"fantástico\", \"eficiente\", \"rápido\", \"bonito\", \"confiável\",\n",
        " \"top\", \"qualidade\", \"super\", \"adorei\", \"feliz\"\n",
        "]\n",
        "\n",
        "# Palavras negativas\n",
        "negativos = [\n",
        " \"horrível\", \"péssimo\", \"ruim\", \"lento\", \"caro\",\n",
        " \"odiei\", \"decepcionante\", \"fraco\", \"problema\", \"defeito\",\n",
        " \"terrível\", \"insatisfeito\", \"bugado\", \"difícil\", \"complicado\",\n",
        " \"pior\", \"atrasado\", \"erro\", \"quebrado\", \"inútil\"\n",
        "]"
      ],
      "metadata": {
        "id": "EoTDJN3mV5Cl"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Palavras de contexto (suportes)\n",
        "suportes = [\n",
        " \"produto\", \"serviço\", \"aplicativo\", \"site\", \"atendimento\", \"entrega\",\n",
        " \"sistema\", \"interface\", \"loja\", \"restaurante\", \"empresa\", \"plataforma\"\n",
        "]\n",
        "\n",
        "# Geração dos textos\n",
        "textos = []\n",
        "labels = []\n",
        "\n",
        "for s in suportes:\n",
        "    for p in positivos:\n",
        "        textos.append(f\"{s} {p}\")\n",
        "        labels.append(1)\n",
        "    for n in negativos:\n",
        "        textos.append(f\"{s} {n}\")\n",
        "        labels.append(0)\n",
        "\n",
        "print(f\"Total de exemplos: {len(textos)}\")\n",
        "print(f\"Positivos: {sum(labels)} | Negativos: {len(labels)-sum(labels)}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "_ZHxTgalWl2k",
        "outputId": "c2f46b5c-fa2e-4a16-e6ab-00b19769a601"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Total de exemplos: 480\n",
            "Positivos: 240 | Negativos: 240\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Divisão treino e teste\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    textos, labels, test_size=0.2, random_state=42\n",
        ")\n",
        "\n",
        "print(f\"Treino: {len(X_train)}\")\n",
        "print(f\"Teste: {len(X_test)}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "qpzQ0IQpXTpE",
