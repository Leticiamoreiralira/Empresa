        "print(f\"Dataset: {DATASET}\")\n",
        "print(f\"TEST_SIZE: {TEST_SIZE}\")\n",
        "print(f\"Hidden: {HIDDEN_UNITS}, Activation: {ACTIVATION}, Solver: {SOLVER}\")"
      ],
